          <mxGeometry x="60" y="230" width="120" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="16" value="Nonconformity score&lt;br&gt;s_i = s(X_i, Y_i)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="240" y="230" width="180" height="60" as="geometry"/>
