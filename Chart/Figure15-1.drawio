          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <!-- Sort and Quantile -->
        <mxCell id="20" value="Sort scores&lt;br&gt;s_(1) ≤ s_(2) ≤ ... ≤ s_(n)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="490" y="230" width="200" height="60" as="geometry"/>
