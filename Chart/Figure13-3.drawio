<mxfile>
  <diagram name="Local vs global safety">
    <mxGraphModel dx="1422" dy="762" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="800">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <!-- Title -->
        <mxCell id="2" value="Figure 13-3 Local safety vs global safety" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;fontSize=18;fontStyle=1;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="350" y="20" width="340" height="40" as="geometry"/>
        </mxCell>
        <!-- Left Panel: Local Optimum -->
        <mxCell id="5" value="Local optimum" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;dashed=1;verticalAlign=top;fontSize=16;fontStyle=1;fontColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="40" y="80" width="460" height="440" as="geometry"/>
        </mxCell>
        <!-- Local agents -->
        <mxCell id="10" value="A" style="ellipse;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="100" y="150" width="60" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="11" value="B" style="ellipse;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="300" y="150" width="60" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="12" value="C" style="ellipse;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="200" y="280" width="60" height="60" as="geometry"/>
        </mxCell>
        <!-- Local optimal paths (may create new conflicts) -->
        <mxCell id="15" value="A&apos;s local-best path" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#6c8ebf;strokeWidth=2;fontSize=11;fontStyle=2;dashed=1;exitX=1;exitY=0.5;" edge="1" source="10" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="240" y="250" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="16" value="B&apos;s local-best path" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#82b366;strokeWidth=2;fontSize=11;fontStyle=2;dashed=1;exitX=0;exitY=1;" edge="1" source="11" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="240" y="260" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <!-- New conflict zone -->
        <mxCell id="18" value="New conflict!" style="shape=mxgraph.flowchart.annotation_2;align=center;labelPosition=center;verticalLabelPosition=middle;verticalAlign=middle;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#CC0000;fontSize=12;fontColor=#CC0000;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="210" y="230" width="60" height="40" as="geometry"/>
        </mxCell>
        <!-- Local description -->
        <mxCell id="19" value="Each agent optimizes alone&lt;br&gt;→ new conflicts may appear&lt;br&gt;→ cascade risk" style="text;html=1;align=center;verticalAlign=middle;fontSize=12;fontColor=#b85450;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="80" y="400" width="380" height="60" as="geometry"/>
        </mxCell>
        <!-- VS Separator -->
        <mxCell id="50" value="VS" style="text;html=1;align=center;verticalAlign=middle;fontSize=24;fontColor=#999999;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="500" y="270" width="60" height="40" as="geometry"/>
        </mxCell>
        <!-- Right Panel: Global Coordination -->
        <mxCell id="6" value="Global coordination" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;dashed=1;verticalAlign=top;fontSize=16;fontStyle=1;fontColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="570" y="80" width="460" height="440" as="geometry"/>
        </mxCell>
        <!-- Global optimizer -->
        <mxCell id="25" value="System-level optimizer" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="720" y="120" width="160" height="50" as="geometry"/>
        </mxCell>
        <!-- Global agents -->
        <mxCell id="30" value="A" style="ellipse;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="630" y="240" width="60" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="31" value="B" style="ellipse;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="830" y="240" width="60" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="32" value="C" style="ellipse;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="730" y="370" width="60" height="60" as="geometry"/>
        </mxCell>
        <!-- Coordinated paths (no conflicts) -->
        <mxCell id="33" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#6c8ebf;strokeWidth=2;dashed=1;" edge="1" source="30" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="660" y="380" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="34" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#82b366;strokeWidth=2;dashed=1;" edge="1" source="31" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="860" y="380" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <!-- Optimizer connections -->
        <mxCell id="36" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#d6b656;strokeWidth=1;dashed=1;" edge="1" source="25" target="30" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="37" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#d6b656;strokeWidth=1;dashed=1;" edge="1" source="25" target="31" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="38" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#d6b656;strokeWidth=1;dashed=1;" edge="1" source="25" target="32" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <!-- Safe check mark -->
        <mxCell id="39" value="No cascade conflict ✓" style="text;html=1;align=center;verticalAlign=middle;fontSize=13;fontColor=#82b366;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="700" y="320" width="120" height="30" as="geometry"/>
        </mxCell>
        <!-- Global description -->
        <mxCell id="40" value="System optimizer coordinates all agents&lt;br&gt;→ globally assigned routes&lt;br&gt;→ no cascading conflicts" style="text;html=1;align=center;verticalAlign=middle;fontSize=12;fontColor=#82b366;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="610" y="440" width="380" height="60" as="geometry"/>
        </mxCell>
        <!-- Bottom: Tension -->
        <mxCell id="55" value="Trade-off: higher local efficiency, lower safety ↔ higher global safety, higher compute cost" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="260" y="560" width="540" height="50" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
