        <mxCell id="42" value="researches [2019–present]" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;fontSize=11;fontColor=#0000CC;strokeColor=#d6b656;strokeWidth=2;" edge="1" source="30" target="33" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="43" value="offers [2020–present]" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;fontSize=11;fontColor=#0000CC;strokeColor=#82b366;strokeWidth=2;" edge="1" source="31" target="33" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <!-- Temporal annotation -->
        <mxCell id="44" value="Quadruple: (h, r, t, τ)&lt;br&gt;τ = timestamp / validity interval" style="text;html=1;align=center;verticalAlign=middle;fontSize=13;fontColor=#0000CC;fontStyle=3;" vertex="1" parent="1">
          <mxGeometry x="680" y="460" width="220" height="40" as="geometry"/>
        </mxCell>
        <!-- Arrow between panels -->
        <mxCell id="50" value="Temporal extension" style="shape=mxgraph.arrows2.arrow;dy=0.6;dx=40;notch=0;fillColor=#e6d0de;strokeColor=#996185;fontSize=13;fontStyle=1;html=1;" vertex="1" parent="1">
