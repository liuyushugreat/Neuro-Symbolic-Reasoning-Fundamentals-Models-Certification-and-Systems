        <mxCell id="41" value="graduated from [2014–2018]" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;fontSize=11;fontColor=#0000CC;strokeColor=#82b366;strokeWidth=2;" edge="1" source="30" target="32" parent="1">
