          <mxGeometry x="740" y="380" width="100" height="50" as="geometry"/>
        </mxCell>
        <!-- Temporal KG Edges with timestamps -->
        <mxCell id="40" value="employed at [2018–present]" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;fontSize=11;fontColor=#0000CC;strokeColor=#6c8ebf;strokeWidth=2;" edge="1" source="30" target="31" parent="1">
          <mxGeometry relative="1" as="geometry"/>
