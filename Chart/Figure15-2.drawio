        </mxCell>
        <mxCell id="13" value="Class C&lt;br&gt;p=0.30" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="300" y="170" width="100" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="14" value="Class D&lt;br&gt;p=0.10" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#cccccc;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="420" y="170" width="60" height="60" as="geometry"/>
        </mxCell>
        <!-- Prediction set -->
        <mxCell id="20" value="Prediction set C(X)" style="text;html=1;align=center;verticalAlign=middle;fontSize=14;fontStyle=1;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="60" y="270" width="120" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="21" value="C(X) = { Class A, Class C }" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=14;fontStyle=1;strokeWidth=3;" vertex="1" parent="1">
          <mxGeometry x="60" y="310" width="380" height="60" as="geometry"/>
        </mxCell>
        <!-- Arrow showing selection -->
        <mxCell id="22" value="s(x,y) ≤ q̂" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#82b366;strokeWidth=2;fontSize=11;fontStyle=2;fontColor=#82b366;" edge="1" source="11" target="21" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="23" value="s(x,y) ≤ q̂" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#82b366;strokeWidth=2;fontSize=11;fontStyle=2;fontColor=#82b366;" edge="1" source="13" target="21" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <!-- Coverage note for classification -->
        <mxCell id="25" value="Guarantee: P(Y ∈ C(X)) ≥ 1−α&lt;br&gt;True label lies in the set with high probability" style="text;html=1;align=center;verticalAlign=middle;fontSize=12;fontColor=#82b366;fontStyle=2;" vertex="1" parent="1">
