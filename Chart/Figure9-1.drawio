        <!-- Query input -->
        <mxCell id="10" value="Query input" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="60" y="230" width="120" height="50" as="geometry"/>
        </mxCell>

        <!-- Three parallel paths -->
        <!-- Path 1: SPARQL -->
        <mxCell id="20" value="SPARQL&lt;br&gt;Exact query" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="280" y="100" width="140" height="55" as="geometry"/>
        </mxCell>

        <!-- Path 2: GraphRAG -->
        <mxCell id="30" value="GraphRAG&lt;br&gt;Semantic retrieval" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="280" y="230" width="140" height="55" as="geometry"/>
        </mxCell>

        <!-- Path 3: LLM -->
        <mxCell id="40" value="LLM&lt;br&gt;NL generation" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="280" y="360" width="140" height="55" as="geometry"/>
        </mxCell>

        <!-- Branching edges -->
        <mxCell id="50" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#82b366;strokeWidth=2;endArrow=block;endFill=1;" edge="1" source="10" target="20" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="51" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#6c8ebf;strokeWidth=2;endArrow=block;endFill=1;" edge="1" source="10" target="30" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="52" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#9673a6;strokeWidth=2;endArrow=block;endFill=1;" edge="1" source="10" target="40" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Evidence fusion -->
        <mxCell id="60" value="Evidence fusion" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=14;fontStyle=1;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="530" y="215" width="140" height="60" as="geometry"/>
        </mxCell>

        <!-- Merge edges -->
        <mxCell id="61" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#82b366;strokeWidth=2;endArrow=block;endFill=1;" edge="1" source="20" target="60" parent="1">
          <mxGeometry relative="1" as="geometry"/>
