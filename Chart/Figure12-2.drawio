        <!-- Title -->
        <mxCell id="2" value="Figure 12-2 Relation-aware graph attention computation flow" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;fontSize=18;fontStyle=1;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="330" y="20" width="380" height="40" as="geometry"/>
        </mxCell>
        <!-- Input Features -->
        <mxCell id="10" value="Node feature x_i" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="100" width="140" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="11" value="Node feature x_j" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="220" width="140" height="60" as="geometry"/>
