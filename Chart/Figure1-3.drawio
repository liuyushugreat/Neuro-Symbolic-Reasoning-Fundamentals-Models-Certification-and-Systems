        </mxCell>
        <mxCell id="10" value="&lt;b style=&quot;font-size:16px&quot;&gt;Knowledge foundation&lt;/b&gt;&lt;br&gt;&lt;hr&gt;&lt;font style=&quot;font-size:12px&quot;&gt;• Symbolic logic and rule systems&lt;br&gt;• Knowledge graphs and ontologies&lt;br&gt;• Domain knowledge modeling&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14;fontColor=#333333;arcSize=15;verticalAlign=top;spacingTop=5;" vertex="1" parent="1">
