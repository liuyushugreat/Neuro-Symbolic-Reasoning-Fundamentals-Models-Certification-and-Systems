        <mxCell id="20" value="&lt;b style=&quot;font-size:16px&quot;&gt;Reasoning models&lt;/b&gt;&lt;br&gt;&lt;hr&gt;&lt;font style=&quot;font-size:12px&quot;&gt;• Deep learning and graph learning&lt;br&gt;• Neuro-symbolic reasoning&lt;br&gt;• Rule injection and knowledge distillation&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=14;fontColor=#333333;arcSize=15;verticalAlign=top;spacingTop=5;" vertex="1" parent="1">
