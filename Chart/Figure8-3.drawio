<mxfile>
  <diagram name="PINN schematic">
    <mxGraphModel dx="1422" dy="762" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1000" pageHeight="700">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Title -->
        <mxCell id="2" value="Physics-informed neural network (PINN) schematic" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=18;fontStyle=1;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="300" y="20" width="280" height="40" as="geometry"/>
        </mxCell>

        <!-- Input -->
        <mxCell id="10" value="Input&lt;br&gt;&lt;b&gt;(t, x)&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="60" y="200" width="100" height="60" as="geometry"/>
        </mxCell>

        <!-- Neural Network -->
        <mxCell id="20" value="Neural network" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=16;fontStyle=1;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="240" y="180" width="200" height="100" as="geometry"/>
        </mxCell>
        <!-- NN internal layers hint -->
        <mxCell id="21" value="Hidden layer 1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#bbdefb;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="255" y="220" width="50" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="22" value="Hidden layer 2" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#bbdefb;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="315" y="220" width="50" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="23" value="Hidden layer N" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#bbdefb;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="375" y="220" width="50" height="30" as="geometry"/>
        </mxCell>

        <!-- Output -->
        <mxCell id="30" value="Output&lt;br&gt;&lt;b&gt;u(t, x)&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="520" y="200" width="120" height="60" as="geometry"/>
        </mxCell>

        <!-- Forward edges -->
        <mxCell id="31" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#333333;strokeWidth=2;endArrow=block;endFill=1;" edge="1" source="10" target="20" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="32" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#333333;strokeWidth=2;endArrow=block;endFill=1;" edge="1" source="20" target="30" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Observed data -->
        <mxCell id="40" value="Observed data&lt;br&gt;&lt;font color=&quot;#666666&quot; style=&quot;font-size:11px&quot;&gt;u_observed&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="520" y="80" width="120" height="55" as="geometry"/>
        </mxCell>

        <!-- 数据损失 -->
        <mxCell id="50" value="① Data loss&lt;br&gt;&lt;font style=&quot;font-size:11px&quot; color=&quot;#666666&quot;&gt;L_data = ||u - u_obs||²&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="700" y="110" width="200" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="51" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#d6b656;strokeWidth=2;endArrow=block;endFill=1;" edge="1" source="30" target="50" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="52" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#d6b656;strokeWidth=2;endArrow=block;endFill=1;" edge="1" source="40" target="50" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- PDE Residual -->
        <mxCell id="60" value="PDE (physics equation)&lt;br&gt;&lt;font color=&quot;#666666&quot; style=&quot;font-size:11px&quot;&gt;F(u) = 0&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="520" y="340" width="120" height="55" as="geometry"/>
        </mxCell>

        <!-- 物理残差损失 -->
        <mxCell id="70" value="② Physics residual loss&lt;br&gt;&lt;font style=&quot;font-size:11px&quot; color=&quot;#666666&quot;&gt;L_physics = ||F(u)||²&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="700" y="310" width="200" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="71" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#b85450;strokeWidth=2;endArrow=block;endFill=1;" edge="1" source="30" target="70" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="72" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#b85450;strokeWidth=2;endArrow=block;endFill=1;" edge="1" source="60" target="70" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Total loss -->
        <mxCell id="80" value="Overall training objective&lt;br&gt;&lt;b&gt;L = L_data + L_physics&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=14;fontStyle=0;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="720" y="210" width="200" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="81" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#82b366;strokeWidth=2;endArrow=block;endFill=1;" edge="1" source="50" target="80" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="82" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#82b366;strokeWidth=2;endArrow=block;endFill=1;" edge="1" source="70" target="80" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
