        </mxCell>
        <!-- No drift -->
        <mxCell id="5" value="continue normal operation" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="300" y="250" width="120" height="50" as="geometry"/>
        </mxCell>
        <!-- Severity Assessment -->
        <mxCell id="6" value="severity assessment" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="540" y="90" width="150" height="60" as="geometry"/>
        </mxCell>
        <!-- Mild -->
        <mxCell id="7" value="mild drift" style="rhombus;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="540" y="220" width="130" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="8" value="flag for review&lt;br&gt;&lt;font style=&quot;font-size:11px;&quot;&gt;• log drift events&lt;br&gt;• enqueue for human review&lt;br&gt;• continue running&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;fontStyle=0;" vertex="1" parent="1">
          <mxGeometry x="520" y="340" width="170" height="100" as="geometry"/>
        </mxCell>
        <!-- Moderate -->
        <mxCell id="9" value="moderate drift" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="740" y="220" width="130" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="10" value="trigger recalibration&lt;br&gt;&lt;font style=&quot;font-size:11px;&quot;&gt;• auto-refresh calibration set&lt;br&gt;• recompute thresholds&lt;br&gt;• temporarily lower confidence&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;fontStyle=0;" vertex="1" parent="1">
          <mxGeometry x="720" y="340" width="170" height="100" as="geometry"/>
        </mxCell>
        <!-- Severe -->
        <mxCell id="11" value="severe drift" style="rhombus;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="940" y="220" width="130" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="12" value="System degradation / human takeover&lt;br&gt;&lt;font style=&quot;font-size:11px;&quot;&gt;• switch to safe mode&lt;br&gt;• raise emergency alert&lt;br&gt;• human-in-the-loop decision&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=13;fontStyle=0;" vertex="1" parent="1">
          <mxGeometry x="920" y="340" width="170" height="100" as="geometry"/>
        </mxCell>
        <!-- Edges -->
        <mxCell id="13" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#666666;strokeWidth=2;" edge="1" source="3" target="4" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="14" value="No" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#82b366;strokeWidth=2;fontSize=13;fontStyle=1;fontColor=#82b366;" edge="1" source="4" target="5" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="15" value="Yes" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#b85450;strokeWidth=2;fontSize=13;fontStyle=1;fontColor=#b85450;" edge="1" source="4" target="6" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="16" value="mild" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#82b366;strokeWidth=2;fontSize=12;fontColor=#82b366;" edge="1" source="6" target="7" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="17" value="moderate" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#d6b656;strokeWidth=2;fontSize=12;fontColor=#d6b656;" edge="1" source="6" target="9" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="18" value="severe" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#b85450;strokeWidth=2;fontSize=12;fontColor=#b85450;" edge="1" source="6" target="11" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="19" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#82b366;strokeWidth=2;" edge="1" source="7" target="8" parent="1">
