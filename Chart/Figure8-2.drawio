        <!-- Variants -->
        <mxCell id="60" value="Variants" style="text;html=1;align=left;verticalAlign=top;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=13;fontStyle=1;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="570" y="400" width="90" height="25" as="geometry"/>
        </mxCell>
        <mxCell id="61" value="Posterior regularization&lt;br&gt;(Posterior Regularization)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="560" y="430" width="170" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="62" value="Co-training&lt;br&gt;(Co-training)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="560" y="480" width="170" height="40" as="geometry"/>
